# =============================================================================
# RECON - Environment Variables
# Copy this file to .env and fill in values
# =============================================================================

# Database (local dev uses docker-compose postgres)
DATABASE_URL="postgresql://recon:dev@localhost:5432/recon_dev"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email (local dev uses Mailpit on port 1025)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@recon.app"

# AWS (not needed for local development)
AWS_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# AWS SES (production only, local dev uses Mailpit)
# SES_FROM_EMAIL="noreply@yourdomain.com"

# AWS S3
# S3_BUCKET="recon-assets"

# Outscraper API
OUTSCRAPER_API_KEY=""

# Anthropic (Claude AI for review analysis — fallback when LM Studio/Ollama unavailable)
ANTHROPIC_API_KEY=""

# Resend (email sending — works locally and on Vercel, no SMTP/SES required)
# Get a free API key at https://resend.com/api-keys
RESEND_API_KEY=""
# Default sender: onboarding@resend.dev works for testing without domain setup
# EMAIL_FROM="RECON <onboarding@resend.dev>"

# Google Maps (browser) - JS API + Places
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
# Google Maps ID for custom map styling (optional, cloud-based style)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=""

# ─── Local LLM (pick ONE — priority: LOCAL_LLM_BASE_URL > LM Studio > Ollama) ───
# If NEITHER is set, the app falls back to Claude API (needs ANTHROPIC_API_KEY).

# Option A: Ollama (Recommended — CLI, press-and-play)
# Install + pull model: `pnpm setup:ai`
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL="gemma3:4b"

# Option B: LM Studio (GUI alternative)
# LM_STUDIO_BASE_URL="http://localhost:1234/v1"
# LM_STUDIO_MODEL="google/gemma-3-4b-it"

# Option C: Any OpenAI-compatible endpoint (overrides both above)
# LOCAL_LLM_BASE_URL=""
# LOCAL_LLM_MODEL=""

# Mapbox (legacy, no longer used - kept for backwards compat)
# NEXT_PUBLIC_MAPBOX_TOKEN=""

# Sentry (optional in dev)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
