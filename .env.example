# =============================================================================
# RECON - Environment Variables
# Copy this file to .env and fill in values
# =============================================================================

# Database (local dev uses docker-compose postgres)
DATABASE_URL="postgresql://recon:dev@localhost:5432/recon_dev"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email (local dev uses Mailpit on port 1025)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@recon.app"

# AWS (not needed for local development)
AWS_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# AWS SES (production only, local dev uses Mailpit)
# SES_FROM_EMAIL="noreply@yourdomain.com"

# AWS S3
# S3_BUCKET="recon-assets"

# Outscraper API
OUTSCRAPER_API_KEY=""

# Anthropic (Claude AI for review analysis)
ANTHROPIC_API_KEY=""

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Sentry (optional in dev)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
